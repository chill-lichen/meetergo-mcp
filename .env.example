# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# Required: your meetergo Bearer token.
#   - Personal Access Token ("rgo-...")  = automates YOUR own workspace (recommended)
#   - Platform API Key ("ak_live:uuid:secret") = multi-user platform access
MEETERGO_API_KEY=

# Optional: only needed with a Platform API Key, to act on behalf of a user.
MEETERGO_USER_ID=

# Optional: override the API base URL (default shown).
MEETERGO_API_BASE=https://api.meetergo.com/v4

# Optional: per-request timeout in seconds (default 30).
MEETERGO_TIMEOUT=30
